# ── Default: normalize line endings to LF in the repo ─────────────────────────
* text=auto eol=lf

# ── Force LF for all text source files ───────────────────────────────────────
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.env       text eol=lf
*.conf      text eol=lf
*.txt       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.sql       text eol=lf
Dockerfile* text eol=lf
Makefile    text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# ── Binary files — never diff/merge ──────────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary
*.sarif     binary

# ── GitHub linguist overrides ────────────────────────────────────────────────
# Tell GitHub this is Python + TypeScript, not YAML-heavy DevOps boilerplate
*.yml       linguist-detectable=false
*.yaml      linguist-detectable=false
Dockerfile* linguist-detectable=false
